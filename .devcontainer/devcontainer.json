{
    "name": "Java 18 Codespace with LFS",
    "image": "mcr.microsoft.com/vscode/devcontainers/java:18-bullseye",
    "features": {
        "ghcr.io/devcontainers/features/git-lfs:1": {}
    },
    "customizations": {
        "vscode": {
            "settings": {
                "java.jdt.ls.java.home": "/usr/local/openjdk-18"
            },
            "extensions": [
                "vscjava.vscode-java-pack"
            ]
        }
    }
}